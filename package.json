{
  "name": "iguzman",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "new-app": "bash cli/new-nextjs-app/new-nextjs-app.sh",
    "new-api": "bash cli/new-django-app/new-django-app.sh",
    "new-tv-app": "bash cli/new-smarttv-app/new-smarttv-app.sh",
    "setup-minecraft": "bash cli/setup-minecraft/setup-minecraft.sh",
    "tv-cert": "bash cli/tv-cert/tv-cert.sh",
    "tv-deploy": "bash cli/tv-deploy/tv-deploy.sh",
    "helm": "bash cli/helm/helm.sh",
    "secrets": "bash cli/setup-k8s-secrets/setup-k8s-secrets.sh",
    "logs": "bash cli/logs/logs.sh",
    "sync-website-hosts": "node scripts/sync-website-hosts.mjs",
    "deploy-app": "bash cli/deploy-app/deploy-app.sh",
    "django-superuser": "bash cli/django-superuser/django-superuser.sh",
    "deploy-postgres": "bash cli/deploy-postgres/deploy-postgres.sh",
    "deploy-mongodb": "bash cli/deploy-mongodb/deploy-mongodb.sh",
    "deploy-mysql": "bash cli/deploy-mysql/deploy-mysql.sh",
    "deploy-redis": "bash cli/deploy-redis/deploy-redis.sh",
    "dev-services": "bash cli/dev-services/dev-services.sh",
    "generate-icons": "bash cli/generate-icons/generate-icons.sh"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "mongodb": "^7.3.0",
    "next": "16.3.0-canary.66"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<10.2.3": ">=10.2.3",
      "ajv@<6.14.0": "^6.14.0",
      "@swc/helpers": ">=0.5.17",
      "rollup@<2.80.0": "2.80.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "serialize-javascript@<7.0.5": "7.0.5",
      "lodash@<=4.17.23": "4.18.1",
      "next": "16.3.0-canary.66",
      "next-intl@<4.9.1": ">=4.9.1",
      "fastify@>=5.3.2 <=5.8.4": ">=5.8.5",
      "protobufjs@<7.5.5": ">=7.5.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "next": "16.3.0-canary.66"
      }
    }
  }
}
