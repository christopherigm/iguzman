# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info          # trace | debug | info | warn | error

# ── Authentication ─────────────────────────────────────────────────────────────
# API key required on every request via X-API-Key header.
# Leave empty to disable auth (development only).
API_KEY=your-strong-api-key-here

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Required: a HuggingFace access token with access to gated pyannote models.
# Accept the terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
# Then generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Model configuration ────────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
# Larger models are more accurate but slower and require more memory.
# Recommended for CPU-only: base (default) or small
WHISPER_MODEL_SIZE=base

# ── Deployment ─────────────────────────────────────────────────────────────────
DOCKER_REGISTRY=christopherguzman
NAMESPACE=diarization
