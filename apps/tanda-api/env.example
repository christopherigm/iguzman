# Docker / Helm
DOCKER_REGISTRY=christopherguzman
NAMESPACE=tanda-api

# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=tanda_api.settings

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://tanda.iguzman.com.mx
CSRF_TRUSTED_ORIGINS=https://tanda-api.iguzman.com.mx,https://tanda.iguzman.com.mx
FRONTEND_URL=https://tanda.iguzman.com.mx

# Database (leave DB_HOST empty to use SQLite locally)
DB_HOST=postgres.tanda-api.svc.cluster.local
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Media (local dev - ignored when R2_ACCOUNT_ID is set)
MEDIA_ROOT=/app/media

# Cloudflare R2 storage (leave R2_ACCOUNT_ID empty to use local filesystem)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=
REDIS_URL=redis://redis.tanda-api.svc.cluster.local:6379/0
REDIS_PASSWORD=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Tanda Api
WEBAUTHN_RP_ORIGIN=http://localhost:3000
