DOCKER_REGISTRY=christopherguzman
NAMESPACE=edge-folio

# Django API base URL — server-side only, never NEXT_PUBLIC_
# Local: http://localhost:8000
# Production: https://api-edge-folio.iguzman.com.mx
API_URL=http://localhost:8000

# Groq API key — server-side only, never NEXT_PUBLIC_
# Used by /api/groq/chat to power AI enhance in the Immutable Matrix form
# Get yours at https://console.groq.com
GROQ_API_KEY=

# Edge model config — exposed to the browser (NEXT_PUBLIC_)
# Set these to trigger background model download during onboarding.
# NEXT_PUBLIC_EDGE_MODEL_ID: HuggingFace model id, e.g. google/gemma-3-4b-it
# NEXT_PUBLIC_EDGE_MODEL_FILES: JSON array of file paths within the model repo
# NEXT_PUBLIC_EDGE_MODEL_REVISION: branch/tag (defaults to "main" if omitted)
NEXT_PUBLIC_EDGE_MODEL_ID=onnx-community/gemma-4-E2B-it-ONNX
NEXT_PUBLIC_EDGE_MODEL_FILES=["onnx/decoder_model_merged_q4f16.onnx","onnx/decoder_model_merged_q4f16.onnx_data","onnx/embed_tokens_q4f16.onnx","onnx/embed_tokens_q4f16.onnx_data","tokenizer.json","tokenizer_config.json","generation_config.json","preprocessor_config.json"]
NEXT_PUBLIC_EDGE_MODEL_REVISION=main
