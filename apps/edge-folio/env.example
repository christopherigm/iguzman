DOCKER_REGISTRY=christopherguzman
NAMESPACE=edge-folio

# Django API base URL - server-side only, never NEXT_PUBLIC_
# Local: http://localhost:8000
# Production: https://api-edge-folio.iguzman.com.mx
API_URL=http://localhost:8000

# Groq API key - server-side only, never NEXT_PUBLIC_
# Used by /api/groq/chat to power AI enhance in the Immutable Matrix form
# Used by /api/scraper/extract to parse job postings into structured fields
# Get yours at https://console.groq.com
GROQ_API_KEY=

# OpenRouter fallback - used by /api/groq/chat when Groq returns 429
# Get your API key at https://openrouter.ai/keys
# Use a plain instruct model here, NOT a reasoning model: generic OpenRouter
# providers leak chain-of-thought into the response and break structured output.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Scraper API key - server-side only, never NEXT_PUBLIC_
# Used by /api/scraper/extract to fetch job posting pages
# Contact the scraper service owner or set SCRAPER_API_KEY= to use in open/dev mode
SCRAPER_API_KEY=
NEXT_PUBLIC_ENABLE_SW=true

# Edge model config - exposed to the browser (NEXT_PUBLIC_)
# Set these to trigger background model download during onboarding.
NEXT_PUBLIC_EDGE_MODEL_ID=onnx-community/Qwen2.5-Coder-1.5B-Instruct
NEXT_PUBLIC_EDGE_MODEL_FILES=["onnx/model_q4f16.onnx","onnx/model.onnx_data","config.json","tokenizer.json","tokenizer_config.json","generation_config.json","special_tokens_map.json"]
NEXT_PUBLIC_EDGE_MODEL_REVISION=main
