# syntax=docker.io/docker/dockerfile:1

FROM node:20-alpine AS base

# ---------------------------------------------------------------------------
# Stage 1 – Prune the monorepo so only packages needed by "edge-folio" are kept.
# This avoids installing unnecessary workspace dependencies.
# ---------------------------------------------------------------------------
FROM base AS pruner
RUN npm install -g turbo@^2
WORKDIR /app
COPY . .
RUN turbo prune edge-folio --docker

# ---------------------------------------------------------------------------
# Stage 2 – Install production + build dependencies (cached layer).
# Only the pruned package.json files and lockfile are copied so that
# source-code changes do not invalidate this layer.
# ---------------------------------------------------------------------------
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

COPY --from=pruner /app/out/json/ ./
RUN corepack enable pnpm && pnpm i --no-frozen-lockfile

# ---------------------------------------------------------------------------
# Stage 3 – Build the Next.js application.
# ---------------------------------------------------------------------------
FROM base AS builder
WORKDIR /app

COPY --from=deps /app/ ./
COPY --from=pruner /app/out/full/ ./

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# NEXT_PUBLIC_* vars are baked into the client bundle at build time by Next.js.
# They cannot be injected at runtime via K8s secrets or container env vars.
ARG NEXT_PUBLIC_ENABLE_SW=true
ARG NEXT_PUBLIC_EDGE_MODEL_ID=onnx-community/gemma-4-E2B-it-ONNX
ARG NEXT_PUBLIC_EDGE_MODEL_REVISION=main
ARG NEXT_PUBLIC_EDGE_MODEL_FILES='["onnx/decoder_model_merged_q4f16.onnx","onnx/decoder_model_merged_q4f16.onnx_data","onnx/decoder_model_merged_q4f16.onnx_data_1","onnx/embed_tokens_q4f16.onnx","onnx/embed_tokens_q4f16.onnx_data","tokenizer.json","tokenizer_config.json","generation_config.json","preprocessor_config.json"]'
ENV NEXT_PUBLIC_ENABLE_SW=$NEXT_PUBLIC_ENABLE_SW
ENV NEXT_PUBLIC_EDGE_MODEL_ID=$NEXT_PUBLIC_EDGE_MODEL_ID
ENV NEXT_PUBLIC_EDGE_MODEL_REVISION=$NEXT_PUBLIC_EDGE_MODEL_REVISION
ENV NEXT_PUBLIC_EDGE_MODEL_FILES=$NEXT_PUBLIC_EDGE_MODEL_FILES

RUN corepack enable pnpm && pnpm exec turbo run build --filter=edge-folio --no-daemon

# @swc/helpers is resolved via Node.js conditional package exports at runtime,
# so Next.js static file tracing misses it in pnpm monorepos.
# pnpm stores @swc/helpers as a symlink inside next@*/node_modules/, so:
#   - use `find -L` to follow symlinks during traversal (matches -type d on symlinked dirs)
#   - increase maxdepth to 5 to account for symlink resolution adding one level
#   - use `cp -rL` to dereference symlinks when copying so the real files land in the image
RUN find -L /app/node_modules/.pnpm -maxdepth 5 \
      -path "*/next@*/node_modules/@swc/helpers" -type d \
    | while read src; do \
        rel="${src#/app/}"; \
        dest="/app/apps/edge-folio/.next/standalone/${rel}"; \
        mkdir -p "$dest"; \
        cp -rL "$src/." "$dest/"; \
      done

# ---------------------------------------------------------------------------
# Stage 4 – Minimal production image.
# Uses the standalone output so node_modules are NOT copied.
# ---------------------------------------------------------------------------
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Runtime system dependencies
RUN apk add --no-cache \
    ffmpeg \
    curl \
    jq \
    wget \
    python3

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy only what the standalone server needs
COPY --from=builder --chown=nextjs:nodejs /app/apps/edge-folio/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/edge-folio/.next/static ./apps/edge-folio/.next/static
# public/ must come last so sw.js and other generated assets are never clobbered
# by anything in the standalone output
COPY --from=builder /app/apps/edge-folio/public ./apps/edge-folio/public

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# server.js is generated by `next build` when output is "standalone"
CMD ["node", "apps/edge-folio/server.js"]
