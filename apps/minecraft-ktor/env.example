DOCKER_REGISTRY=christopherguzman
NAMESPACE=minecraft

# Port the Ktor HTTP server listens on
PORT=8080

# Absolute path to the Architectury template project baked into the image
TEMPLATE_DIR=/opt/mc-template

# Gradle user home — pre-warmed with MC/Architectury deps during Docker build
GRADLE_USER_HOME=/opt/gradle-home

# Temporary directory for per-request build workspaces
BUILD_WORKSPACE_DIR=/tmp/mc-builds
