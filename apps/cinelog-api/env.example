# Docker / Helm
DOCKER_REGISTRY=elizabethguzmanalvarez25
NAMESPACE=cinelog

# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=cinelog_api.settings

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://cinelog.iguzman.com.mx
CSRF_TRUSTED_ORIGINS=https://cinelog-api.iguzman.com.mx,https://cinelog.iguzman.com.mx
FRONTEND_URL=https://cinelog.iguzman.com.mx

# Database (leave DB_HOST empty to use SQLite locally)
DB_HOST=postgres.cinelog.svc.cluster.local
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Media (local dev — ignored when R2_ACCOUNT_ID is set)
MEDIA_ROOT=/app/media

# Cloudflare R2 storage (leave R2_ACCOUNT_ID empty to use local filesystem)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=
REDIS_URL=redis://:redis@redis.cinelog.svc.cluster.local:6379/0
REDIS_PASSWORD=redis
CELERY_BROKER_URL=redis://:redis@redis.cinelog.svc.cluster.local:6379/0
CELERY_RESULT_BACKEND=redis://:redis@redis.cinelog.svc.cluster.local:6379/0
# Local dev: set True to run Celery tasks synchronously in-process (no Redis/worker needed)
CELERY_TASK_ALWAYS_EAGER=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# TMDB
TMDB_API_TOKEN=

# Scraper microservice (Fastify + Playwright)
SCRAPER_BASE_URL=https://scraper.iguzman.com.mx
SCRAPER_API_KEY=

# Hosted LLM — Groq primary, OpenRouter rate-limit fallback
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
# OpenRouter fallback — used when Groq hits its rate limit (429)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Cinelog Api
WEBAUTHN_RP_ORIGIN=http://localhost:3000
