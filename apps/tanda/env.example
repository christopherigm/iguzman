DOCKER_REGISTRY=christopherguzman
NAMESPACE=tanda

# Django API base URL - server-side only, never NEXT_PUBLIC_
# Local: http://localhost:8000
API_URL=https://tanda-api.iguzman.com.mx

# LLM (AI Analysis) - server-side only, never NEXT_PUBLIC_
# Groq is the primary provider for /api/groq/chat; OpenRouter is the 429 fallback.
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Model used only for the OpenRouter fallback (defaults to llama-3.3-70b-instruct)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Web-search enrichment (AI Analysis) - server-side only, never NEXT_PUBLIC_
# API key for the scraper service used by /api/groq/enrich (search + extract).
SCRAPER_API_KEY=
# Optional: model used to build the search queries (defaults to llama-3.1-8b-instant)
GROQ_QUERY_MODEL=llama-3.1-8b-instant
