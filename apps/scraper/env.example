# Port the server listens on (default: 4000)
PORT=4000

# API key required on every request via the X-API-Key header.
# Leave empty to disable auth (development only).
SCRAPER_API_KEY=your-strong-api-key-here

# Log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# ── Deployment ────────────────────────────────────────────────
DOCKER_REGISTRY=christopherguzman
NAMESPACE=scraper

# Brave Search API key — third-fallback search engine (https://brave.com/search/api/)
BRAVE_API_KEY=your-brave-api-key-here

# File Secrets (path is read and content embedded in the secret)
COOKIES_FILE=
WG_CONFIG_FILE=

# ── Brightdata Residential Proxy ──────────────────────────────
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
