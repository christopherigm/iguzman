DOCKER_REGISTRY=docker
NAMESPACE=video-downloader-2

# R2 Object Storage (Cloudflare)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Groq API
GROQ_API_KEY=

# OpenRouter fallback - used by /api/groq/chat when Groq returns 429
# Get your API key at https://openrouter.ai/keys
# Use a plain instruct model here, NOT a reasoning model: a reasoning model spends
# its token budget thinking and returns empty/length-truncated translations.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ScrapeCreators API
SCRAPECREATORS_API_KEY=

# Stripe (credits system)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Internal
INTERNAL_SECRET=

# Diarization service
DIARIZATION_URL=http://diarization.diarization.svc.cluster.local
DIARIZATION_API_KEY=

# MongoDB
MONGO_URI=

# Logging
LOG_LEVEL=info

# File Secrets (path is read and content embedded in the secret)
COOKIES_FILE=
WG_CONFIG_FILE=
