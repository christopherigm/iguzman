    "build": {
      "env": ["NEXT_PUBLIC_BASE_URL"],
      "passThroughEnv": [
        "LOG_LEVEL",
        "INTERNAL_SECRET",
        "DIARIZATION_URL",
        "DIARIZATION_API_KEY",
        "GROQ_API_KEY",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "SCRAPECREATORS_API_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "R2_ACCOUNT_ID",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET_NAME",
        "R2_PUBLIC_URL"
      ]
