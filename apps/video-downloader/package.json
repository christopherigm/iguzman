    "react-dom": "^19.2.4",
    "stripe": "^22.1.1",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
