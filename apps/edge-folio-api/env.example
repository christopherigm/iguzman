# Docker / Helm
DOCKER_REGISTRY=christopherguzman
NAMESPACE=edge-folio

# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=edge_folio_api.settings

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://edge-folio.iguzman.com.mx
CSRF_TRUSTED_ORIGINS=https://api-edge-folio.iguzman.com.mx,https://edge-folio.iguzman.com.mx
FRONTEND_URL=https://edge-folio.iguzman.com.mx

# Database (leave DB_HOST empty to use SQLite locally)
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Media (local dev — ignored when R2_ACCOUNT_ID is set)
MEDIA_ROOT=/app/media

# Cloudflare R2 storage (leave R2_ACCOUNT_ID empty to use local filesystem)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=media.iguzman.com.mx

REDIS_URL=redis://redis.edge-folio.svc.cluster.local:6379/0
REDIS_PASSWORD=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.ionos.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Edge Folio
WEBAUTHN_RP_ORIGIN=http://localhost:3000

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# OpenRouter fallback — used when Groq hits its rate limit (429)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b

SCRAPER_API_KEY=
SCRAPER_URL=https://scraper.iguzman.com.mx
